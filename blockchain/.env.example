# Sepolia deployment secrets — template.
#
# Copy this file to `.env` (which is git-ignored) and fill in real values:
#     cp .env.example .env
# NEVER commit real values. Only `.env.example` (placeholders) is tracked.
#
# These are read by hardhat.config.ts via configVariable(...). As an alternative to
# this file you may store them in Hardhat's encrypted keystore instead (see the
# deploy runbook); either source works.

# JSON-RPC endpoint for Sepolia (e.g. Alchemy / Infura). Include your API key.
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Private key of a THROWAWAY test wallet funded with Sepolia faucet ETH only.
# Never use a wallet that holds real funds. Must start with 0x.
SEPOLIA_PRIVATE_KEY=0xYOUR_TEST_WALLET_PRIVATE_KEY
